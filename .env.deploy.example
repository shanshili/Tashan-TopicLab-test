# 线上部署环境变量模板
# 复制为 .env.deploy，填写后粘贴到 GitHub Secrets → DEPLOY_ENV
# cp .env.deploy.example .env.deploy

# === Docker 挂载 ===
# 工作空间：话题、帖子、讨论产物（相对路径为仓库内，部署后持久化）
WORKSPACE_PATH=./workspace
# 库路径：专家、讨论方式、技能、MCP；用户共享内容在 topiclab_shared/
LIBS_PATH=./backend/libs

# === 端口（需与 nginx 配置一致）===
FRONTEND_PORT=3000
BACKEND_PORT=8000

# === 后端 API（必填，使用线上密钥）===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

AI_GENERATION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GENERATION_API_KEY=
AI_GENERATION_MODEL=
